{
  "expo": {
    "name": "Tu App Food",
    "slug": "tu-app-food",
    "scheme": "tu-app-food",
    "owner": "gabriel1238",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tucompany.tufoodapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.tucompany.tufoodapp",
      "googleServicesFile": "./google-services.json",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "pan",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDCMaAPbINbqR6pKvj0JdBGfCe7-7ny62s"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      ["expo-notifications", {
        "icon": "./assets/notification-icon.png",
        "color": "#ff8700",
        "defaultChannel": "default"
      }],
      ["expo-build-properties", {
        "android": {
          "compileSdkVersion": 36,
          "targetSdkVersion": 36,
          "minSdkVersion": 26
        }
      }]
    ],
    "experiments": {
      "tsconfigPaths": false
    },
    "extra": {
      "eas": {
        "projectId": "33784b9f-ca85-4f3c-b39a-5fe5939ef40a",
        "mapsUserAgent": "TuNombreApp/1.0 (contacto@tuemail.com)"
      }
    }
  }
}
